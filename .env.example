# Watchtower Configuration
WATCHTOWER_POLL_INTERVAL=300
WATCHTOWER_CLEANUP=true
WATCHTOWER_PORT=8081

# HTTP API (for webhook triggers)
WATCHTOWER_HTTP_API_UPDATE=true
WATCHTOWER_HTTP_API_TOKEN=changeme

# Email Notifications (Stalwart SMTP)
WATCHTOWER_NOTIFICATIONS=email
WATCHTOWER_NOTIFICATION_EMAIL_FROM=github@lmcustoms.cc
WATCHTOWER_NOTIFICATION_EMAIL_TO=anian@lmcustoms.cc
WATCHTOWER_NOTIFICATION_EMAIL_SERVER=mail.sollingers.de
WATCHTOWER_NOTIFICATION_EMAIL_SERVER_PORT=587
WATCHTOWER_NOTIFICATION_EMAIL_SERVER_USER=github@lmcustoms.cc
WATCHTOWER_NOTIFICATION_EMAIL_SERVER_PASSWORD=changeme
